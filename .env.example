# kis-cli 컨테이너 시크릿/설정.
# 사용법: cp .env.example .env  후 값 채우기. (.env 는 절대 커밋 금지 — .gitignore 에 포함)

# ─── KIS 자격증명 (필수) ───
# 한국투자증권 OpenAPI(https://apiportal.koreainvestment.com) 신청 후 발급.
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
# 계좌번호: 8자리-2자리 (뒤 2자리는 상품코드 ACNT_PRDT_CD, 보통 01)
KIS_ACCOUNT_NUMBER=12345678-01
# true=모의투자 서버, false=실전투자 서버
KIS_IS_MOCK=true

# ─── 텔레그램 (brief stream / 신호 알림 사용 시) ───
# 둘 다 채워야 텔레그램 기능 활성. 아니면 비워둠.
KIS_TELEGRAM_BOT_TOKEN=
KIS_TELEGRAM_CHAT_ID=

# ─── 로깅 (선택) ───
# RUST_LOG=info
