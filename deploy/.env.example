# kis-cli 배포용 환경변수 (다른 서버) — 플레이스홀더를 실제 값으로 채우세요.
# 사용: cp deploy/.env.example deploy/.env  후 값 입력. (deploy/.env 는 커밋 금지 — .gitignore 처리됨)

# ─────────────────────────────────────────────────────────────
# KIS 자격증명 — 모든 데몬(telegram / daytrade / stop-loss) 공통 필수
# 한국투자증권 OpenAPI(https://apiportal.koreainvestment.com) 신청 후 발급.
# ─────────────────────────────────────────────────────────────
KIS_APP_KEY=<your_app_key>
KIS_APP_SECRET=<your_app_secret>
KIS_ACCOUNT_NUMBER=<00000000-01>          # 계좌 8자리-상품코드(보통 01)
KIS_IS_MOCK=true                          # true=모의투자 서버 / false=실전(실주문!)

# ─────────────────────────────────────────────────────────────
# 텔레그램 — telegram 데몬 / 신호 알림 사용 시 필수 (아니면 비워둠)
# ─────────────────────────────────────────────────────────────
KIS_TELEGRAM_BOT_TOKEN=<telegram_bot_token>
KIS_TELEGRAM_CHAT_ID=<telegram_chat_id>

# ─────────────────────────────────────────────────────────────
# 선택
# ─────────────────────────────────────────────────────────────
# KIS_IMAGE=ghcr.io/preinpost/kis-cli:latest   # 버전 고정하려면 :1.0.22 처럼 태그 지정
# RUST_LOG=info
